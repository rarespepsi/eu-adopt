# Copiază în `.env` și completează. Nu comita `.env`.

# Obligatoriu în producție: cheie aleatoare lungă (ex. `python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"`)
# DJANGO_SECRET_KEY=

# Local: lasă gol sau setează 1 pentru DEBUG. Producție: nu seta sau 0.
# DJANGO_DEBUG=0

# După HTTPS pe domeniu real (Render etc.): deblochează redirect SSL + cookie-uri secure
# DJANGO_SECURE_SSL=1

# URL absolut pentru linkuri în emailuri (fără slash final). În producție setează explicit
# (ex. pe Render), altfel risc de linkuri relative → http:/// în Gmail.
# EUADOPT_SITE_BASE_URL=https://www.eu-adopt.ro
# Local, dacă testezi mailuri cu backend SMTP: EUADOPT_SITE_BASE_URL_DEV=http://127.0.0.1:8000

# SMTP Gmail (parolă de aplicație)
# EMAIL_HOST_PASSWORD=

# Google Maps pe /transport/
# EUADOPT_GOOGLE_MAPS_API_KEY=

# Site public (0 = mod întreținere pe unele deploy-uri)
# SITE_PUBLIC=1
